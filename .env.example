# ─── Convex (set automatically by `npx convex dev`) ─────────────────────────
# Copy these values from .env.local after running: npx convex dev
PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://<your-deployment>.convex.site

# ─── Better Auth (set in Convex dashboard environment variables) ──────────────
# Generate with: openssl rand -base64 32
# Set in Convex dashboard → Settings → Environment variables, NOT in .env
# BETTER_AUTH_SECRET=<generate with openssl rand -base64 32>
# SITE_URL=https://<your-replit-dev-domain>.replit.dev   (or localhost:5000 for local)

# ─── OAuth providers (optional — set in Convex dashboard env vars) ────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
