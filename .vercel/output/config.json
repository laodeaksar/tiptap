{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"headers": {
				"cache-control": "no-store"
			},
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/api/auth(/[^]*)?/?(?:/__data.json)?$",
			"dest": "/api/auth/[...all]"
		},
		{
			"src": "^/doc/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/doc/[id]"
		},
		{
			"src": "^/p/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/p/[id]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}